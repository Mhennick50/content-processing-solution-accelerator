@url = "https://ca-cliniqeckvo-api.lemonforest-208f0ef4.eastus2.azurecontainerapps.io"

#######################
# Container App Health Checks
#######################

GET {{url}}/startup

#############################
# Get All Registered Schemas
#############################

GET {{url}}/schemavault/

#########################################
# Register ClinIQ Patient Record Schema
#########################################

POST {{url}}/schemavault/
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW

------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="file"; filename="patient_record.py"
Content-Type: text/x-python

< ../samples/schemas/patient_record.py
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="data"
Content-Type: application/json

{
  "ClassName": "PatientRecord",
  "Description": "ClinIQ Patient Record Schema v1"
}

------WebKitFormBoundary7MA4YWxkTrZu0gW--

##########################################
# Update Schema (only needed later)
##########################################

PUT {{url}}/schemavault/
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW

------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="file"; filename="patient_record.py"
Content-Type: text/x-python

< ../samples/schemas/patient_record.py
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="data"
Content-Type: application/json

{
  "SchemaId": "PASTE_SCHEMA_ID_HERE",
  "ClassName": "PatientRecord"
}

------WebKitFormBoundary7MA4YWxkTrZu0gW--

########################################
# Get Schema by ID
########################################

GET {{url}}/schemavault/schemas/PASTE_SCHEMA_ID_HERE

########################################
# Delete Schema
########################################

DELETE {{url}}/schemavault/
Content-Type: application/json

{
  "SchemaId": "PASTE_SCHEMA_ID_HERE"
}

#################################
# Upload Patient Record PDF
#################################

POST {{url}}/contentprocessor/submit
Content-Type: multipart/form-data; boundary=----WebKitFormBoundary7MA4YWxkTrZu0gW

------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="file"; filename="patient_record.pdf"
Content-Type: application/pdf

< ../samples/patient_records/patient_record.pdf
------WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="data"
Content-Type: application/json

{
  "Metadata_Id": "ClinIQ_Test_001",
  "Schema_Id": "PASTE_SCHEMA_ID_HERE"
}

------WebKitFormBoundary7MA4YWxkTrZu0gW--

#################################
# Get Processing Status
#################################

GET {{url}}/contentprocessor/status/PASTE_PROCESS_ID_HERE

#################################
# Get Processed Data
#################################

GET {{url}}/contentprocessor/processed/PASTE_PROCESS_ID_HERE

#################################
# Get Processing Steps
#################################

GET {{url}}/contentprocessor/processed/PASTE_PROCESS_ID_HERE/steps

#################################
# Download Original File
#################################

GET {{url}}/contentprocessor/processed/files/PASTE_FILE_ID_HERE

#################################
# Get All Processed Data
#################################

POST {{url}}/contentprocessor/processed
Content-Type: application/json

{
  "page_size": 20,
  "page_number": 1
}

#################################
# Add Comment on Result
#################################

PUT {{url}}/contentprocessor/processed/PASTE_PROCESS_ID_HERE
Content-Type: application/json

{
  "process_id": "PASTE_PROCESS_ID_HERE",
  "comment": "ClinIQ Review Comment"
}

#################################
# Modify Processed Result
#################################

PUT {{url}}/contentprocessor/processed/PASTE_PROCESS_ID_HERE
Content-Type: application/json

{
  "process_id": "PASTE_PROCESS_ID_HERE",
  "modified_result": {}
}